# Backend Environment Variables
# Copy this file to set your local environment variables
# For local development, you can source this file: source env.example

# Server Configuration
PORT=3000

# Database Configuration
# For local development with Docker: mongodb://localhost:27017/honey-store
# For Kubernetes: mongodb://mongodb:27017/honey-store
MONGODB_URI=mongodb://localhost:27017/honey-store

# Payment Service Configuration
# URL of the external payment service (Payment Dashboard)
# Payment Dashboard: http://34.23.213.127/
# API Endpoint: http://34.23.213.127/payment
PAYMENT_SERVICE_URL=http://34.23.213.127

# Backend Public URL (for webhooks)
# For local development: http://localhost:3000
# For ngrok: https://abc123.ngrok.io
# For Kubernetes with LoadBalancer: http://<external-ip>
# Leave empty to use default based on connection method
BACKEND_PUBLIC_URL=http://localhost:3000

# Service Configuration
# Location: 'local' or 'cloud'
SERVICE_LOCATION=local

# Connection Method
# Options: 'direct', 'ngrok', 'telepresence', 'port-forward'
CONNECTION_METHOD=direct

